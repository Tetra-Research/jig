from django.db import migrations, models


class Migration(migrations.Migration):
    dependencies = [
        ("{{ app_label }}", "{{ add_migration_name }}"),
    ]

    operations = [
        migrations.AlterField(
            model_name="{{ model_name | lower }}",
            name="{{ field_name }}",
            field={{ field_type }}({{ final_field_kwargs }}),
        ),
    ]
