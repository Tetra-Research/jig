from django.db import migrations, models


def backfill_{{ field_name }}(apps, schema_editor):
    model_cls = apps.get_model("{{ app_label }}", "{{ model_name }}")
    db_alias = schema_editor.connection.alias

    for row in model_cls.objects.using(db_alias).all().only("id", "{{ field_name }}"):
        if getattr(row, "{{ field_name }}", None) in (None, ""):
            setattr(row, "{{ field_name }}", {{ backfill_value }})
            row.save(update_fields=["{{ field_name }}"])


class Migration(migrations.Migration):
    dependencies = [
        ("{{ app_label }}", "{{ previous_migration }}"),
    ]

    operations = [
        migrations.AddField(
            model_name="{{ model_name | lower }}",
            name="{{ field_name }}",
            field={{ field_type }}({{ add_field_kwargs }}),
        ),
        migrations.RunPython(backfill_{{ field_name }}, migrations.RunPython.noop),
    ]
