tus_code, 400)"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":618,"cache_read_input_tokens":28019,"cache_creation":{"ephemeral_5m_input_tokens":618,"ephemeral_1h_input_tokens":0},"output_tokens":702,"service_tier":"standard","inference_geo":"not_available"}},"parent_tool_use_id":null,"session_id":"788ca503-e2a1-4e3c-ba00-fb957c444bc3","uuid":"b09ab278-c3f8-452d-a718-12d1bad4bc77"}
