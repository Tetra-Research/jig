{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01XPUwzTAdTLR5zqGhVr6Rs8","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_012FTbrtKd5MmnZ8csJLN4fq","name":"Write","input":{"file_path":"/private/var/folders/tj/h5npswhx6lz3f0vdyrxkdzhh0000gn/T/jig-head2head-7caW06/tests/test_core_service.py","content":"from unittest.mock import create_autospec\n\nimport pytest\n\nfrom services.core_service import CoreService\n\n\n@pytest.fixture\ndef service():\n    return CoreService()\n\n\ndef test_create_record_returns_confirmed_status_with_display_name(service):\n    display_name = \"Ada Lovelace\"\n    check_in = \"2024-01-01\"\n    check_out = \"2024-01-02\"\n\n    # Act\n    result = service.create_record(display_name, check_in, check_out)\n\n    assert result == {\n        \"id\": \"abc-123\",\n        \"display_name\": display_name,\n        \"status\": \"confirmed\",\n    }\n\n\ndef test_create_record_preserves_distinct_display_name(service):\n    display_name = \"Grace Hopper\"\n\n    # Act\n    result = service.create_record(display_name, \"2024-02-10\", \"2024-02-12\")\n\n    assert result[\"display_name\"] == \"Grace Hopper\"\n    assert result[\"status\"] == \"confirmed\"\n\n\ndef test_cancel_record_returns_cancelled_status_for_given_id(service):\n    record_id = \"abc-123\"\n\n    # Act\n    result = service.cancel_record(record_id)\n\n    assert result == {\"id\": record_id, \"status\": \"cancelled\"}\n\n\ndef test_cancel_record_echoes_unknown_id_without_mutation(service):\n    record_id = \"does-not-exist\"\n\n    # Act\n    result = service.cancel_record(record_id)\n\n    assert result[\"id\"] == \"does-not-exist\"\n    assert result[\"status\"] == \"cancelled\"\n\n\ndef test_create_record_delegates_via_autospec_boundary():\n    service_mock = create_autospec(CoreService, instance=True)\n    service_mock.create_record.return_value = {\n        \"id\": \"abc-123\",\n        \"display_name\": \"Alan Turing\",\n        \"status\": \"confirmed\",\n    }\n\n    # Act\n    result = service_mock.create_record(\"Alan Turing\", \"2024-03-01\", \"2024-03-03\")\n\n    service_mock.create_record.assert_called_once_with(\n        \"Alan Turing\", \"2024-03-01\", \"2024-03-03\"\n    )\n    assert result[\"status\"] == \"confirmed\"\n\n\ndef test_cancel_record_delegates_via_autospec_boundary():\n    service_mock = create_autospec(CoreService, instance=True)\n    service_mock.cancel_record.return_value = {\n        \"id\": \"abc-123\",\n        \"status\": \"cancelled\",\n    }\n\n    # Act\n    result = service_mock.cancel_record(\"abc-123\")\n\n    service_mock.cancel_record.assert_called_once_with(\"abc-123\")\n    assert result[\"status\"] == \"cancelled\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":287,"cache_read_input_tokens":23190,"cache_creation":{"ephemeral_5m_input_tokens":287,"ephemeral_1h_input_tokens":0},"output_tokens":1014,"service_tier":"standard","inference_geo":"not_available"}},"parent_tool_use_id":null,"session_id":"4cb28024-7c8a-434e-a965-22a83dbe6927","uuid":"dd05d72e-49e8-4608-b6d9-f7065e049420"}
